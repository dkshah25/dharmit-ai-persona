# Scale Persona Platform - Environment Configuration Template
# Copy this file to backend/.env and fill in your keys.

# LLM APIs
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Knowledge Pipeline
GITHUB_TOKEN=your_github_personal_access_token_here

# Scheduling (Cal.com API v1 or v2)
CAL_API_KEY=your_cal_api_key_here
CAL_EVENT_TYPE_ID=your_cal_event_type_id_here
CAL_USERNAME=your_cal_username_here

# Voice Platform (Vapi)
VAPI_API_KEY=your_vapi_api_key_here
VAPI_PRIVATE_KEY=your_vapi_private_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here

# Server Configuration
PORT=8000
PUBLIC_APP_URL=https://your-domain.com
